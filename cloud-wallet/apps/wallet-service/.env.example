# Wallet Service Environment Variables
PORT=3003
NODE_ENV=development

# PostgreSQL Database (shared with Auth Service)
DB_USER=postgres
DB_PASSWORD=FONK2005-
DB_HOST=postgres
DB_PORT=5432
DB_NAME=nexvault_db

# JWT Configuration (same as Auth Service)
JWT_SECRET=fbd204a7-318e-4dd3-86e0-e6d524fc3f98
JWT_EXPIRY=24h
REFRESH_TOKEN_SECRET=fbd204a7-318e-4dd3-86e0-e6d524fc3f98
REFRESH_TOKEN_EXPIRY=7d

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# Transaction Limits
DEFAULT_DAILY_LIMIT=10000.00
DEFAULT_MONTHLY_LIMIT=50000.00
MAX_TRANSACTION_AMOUNT=10000.00

# Currency Settings
DEFAULT_CURRENCY=XAF
SUPPORTED_CURRENCIES=USD,EUR,GBP,XAF

# External API Keys (for payment processors)
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Notification Settings
NOTIFICATION_ENABLED=true
TRANSACTION_NOTIFICATION_ENABLED=true

# Security
ENCRYPTION_KEY=fbd204a7-318e-4dd3-86e0-e6d524fc3f98